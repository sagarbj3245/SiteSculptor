# Copy this file to .env.local and fill in your real values.
# Never put real secrets in this file — it is committed to git.

# OpenAI — used by the API routes for chat, prompt enhancement, and code generation
OPENAI_API_KEY=sk-your-key-here
# Optional: override the default model (defaults to gpt-5.1)
# OPENAI_MODEL=gpt-5.1

# Convex — run `npx convex dev` to provision and fill these automatically
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# Gmail SMTP for the contact form (create an App Password at
# https://myaccount.google.com/apppasswords — requires 2-Step Verification)
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password
